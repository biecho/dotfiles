#!/bin/bash
# Safety net: reject pushes containing Co-Authored-By or AI references.
# Catches commits made with --no-verify that bypassed commit-msg hooks.

remote="$1"
url="$2"

while read local_ref local_oid remote_ref remote_oid; do
    if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
        range="$local_oid"
    else
        range="$remote_oid..$local_oid"
    fi

    offending=$(git log --format="%h %s" "$range" --grep="Co-Authored-By" -i 2>/dev/null)
    if [ -n "$offending" ]; then
        echo "ERROR: Push rejected — commits contain Co-Authored-By lines:"
        echo "$offending"
        echo ""
        echo "Fix with: git rebase -i and reword the offending commits."
        exit 1
    fi
done

exit 0
